{
  "name": "pmo-chatbot-tanstack-start",
  "version": "0.1.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "start": "vite preview",
    "lint": "eslint .",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute site-creator-d1 --config=./dist/server/wrangler.json --local --file=./drizzle/0000_secret_hellfire_club.sql",
    "db:seed": "wrangler d1 execute site-creator-d1 --config=./dist/server/wrangler.json --local --file=./db/seed/ai-command-center.sql",
    "db:migrate:remote": "wrangler d1 execute site-creator-d1 --config=./dist/server/wrangler.json --remote --file=./drizzle/0000_secret_hellfire_club.sql",
    "db:seed:remote": "wrangler d1 execute site-creator-d1 --config=./dist/server/wrangler.json --remote --file=./db/seed/ai-command-center.sql",
    "r2:seed": "powershell -ExecutionPolicy Bypass -File ./scripts/seed-r2.ps1 -Bucket site-creator-r2",
    "r2:seed:remote": "powershell -ExecutionPolicy Bypass -File ./scripts/seed-r2.ps1 -Bucket site-creator-r2 -Remote"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^0.468.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "22.19.19",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "4.92.0"
  }
}
